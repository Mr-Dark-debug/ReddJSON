{
  "manifest_version": 3,
  "name": "ReddJSON — Reddit to LinkedIn AI",
  "version": "2.0.0",
  "description": "Copy Reddit post JSON, generate LinkedIn posts with AI. Sidebar with history, AI posts, and provider settings.",
  "author": "ReddJSON Team",
  "icons": {
    "128": "reddjosn.svg"
  },
  "action": {
    "default_icon": "reddjosn.svg",
    "default_title": "ReddJSON — Open Sidebar"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.reddit.com/*",
    "https://openrouter.ai/*",
    "https://api.groq.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.reddit.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "reddjosn.svg"
      ],
      "matches": [
        "*://*.reddit.com/*"
      ]
    }
  ]
}